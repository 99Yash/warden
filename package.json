{
  "name": "warden",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "check": "oxlint && oxfmt --write",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "db:generate": "turbo run db:generate --filter=@warden/db",
    "db:migrate": "turbo run db:migrate --filter=@warden/db",
    "db:studio": "turbo run db:studio --filter=@warden/db",
    "gen-fixtures": "pnpm --filter @warden/web gen-fixtures",
    "warden": "pnpm --filter @warden/cli warden"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.62.0",
    "tsdown": "^0.15.5",
    "turbo": "^2.8.10"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "overrides": {
      "esbuild@<0.25.0": ">=0.25.0"
    }
  }
}

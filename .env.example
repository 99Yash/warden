# Recommended for `warden review` boss planning. `warden check` is
# deterministic-only and does not need provider keys. If Anthropic is unset
# but OpenAI is set, review uses GPT-5.5 as the boss.
ANTHROPIC_API_KEY=sk-ant-xxxx

# Optional for `warden review`, but preferred for worker dispatch when set.
# With both Anthropic and OpenAI configured, Warden defaults to Claude Opus
# for the boss and GPT-5.4 mini xhigh for workers.
OPENAI_API_KEY=sk-xxxx

# Required for `warden init` — Voyage API key for the embedding-backed
# context index. `warden review` degrades when semantic retrieval is unavailable.
VOYAGE_API_KEY=pa-xxxx

# Optional — Google Generative AI key. When set, enables the multi-provider
# fallback per ADR-0017: Anthropic primary, Google (gemini-2.5-pro/flash)
# as the second provider when Anthropic fails after one retry.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional — log verbosity. silent | error | warn | info (default) | debug
WARDEN_LOG_LEVEL=info

# Optional — confidence floor for `security`-category findings (ADR-0028).
# Comments below this floor are silently dropped before render; Tier-1
# findings bypass unconditionally (critical-finding short-circuit). Default
# 0.8 lives in @warden/core/confidence.ts; set this to lower or raise it.
# Acceptable values: 0.0–1.0.
WARDEN_SECURITY_CONFIDENCE_FLOOR=

# Optional — M14 review-harness boss step cap (ADR-0030). The boss runs as
# a single `streamText` tool-use loop; each round is one step it spends
# dispatching workers or emitting the final comment array. Default 5;
# clamped to [1, 10]. Lower for cost-conscious runs; raise for diffs that
# need deeper adjudication.
WARDEN_REVIEW_BOSS_ROUNDS=

# Optional — M14 review-harness total worker cap across the boss loop
# (ADR-0030). Unset = unbounded (boss self-budgets within the round cap).
# When set, the dispatch tool returns an error to the boss + emits a
# degraded entry past the cap. Positive integer; use the round cap above
# to disable workers entirely (this knob can't be 0).
WARDEN_REVIEW_WORKER_BUDGET=

# Optional — M16 review-time index refresh budget in USD (ADR-0032).
# Default is 0.25 at the review harness call site. Set to 0 to disable
# implicit refresh and keep the existing stale-index banner.
WARDEN_REVIEW_REFRESH_MAX_USD=

# Optional — per-tier dispatch concurrency caps (ADR-0033). Strong and cheap
# are logical worker lanes; the concrete model depends on configured keys.
# Defaults: 4 strong, 8 cheap. Constructed once per runReview() and acquired
# at the dispatch boundary (runOneDispatch) — throttles both Round 0's
# Promise.all fan-out and the boss-loop's in-loop dispatches. Surfaces as
# one aggregated `worker-concurrency` info entry only when the cap engaged.
# Provider-neutral so M18 + BYOLLM inherit. Positive integer; 0 is rejected.
WARDEN_WORKER_CONCURRENCY_STRONG=
WARDEN_WORKER_CONCURRENCY_CHEAP=

# Optional — M18 dedicated security harness worker cap (ADR-0029). Unset =
# unbounded. When set and the boss plans more workers than this number,
# only the first N planned workers run and Warden emits one degraded entry.
# Positive integer; 0 is rejected.
WARDEN_SECURITY_WORKER_BUDGET=

# Optional — opt into the react-doctor det-prior (ADR-0046). Boolean-ish:
# `1`/`true` enable, unset/anything else off. Default off while eval-gated.
# Subprocesses the published react-doctor CLI (via npx) and folds its
# diagnostics in as deterministic `source: "react-doctor"` findings. Zero LLM.
WARDEN_REACT_DOCTOR=

# Optional — the ADR-0048 live observability surface (OTEL spans → self-hosted
# Langfuse). Both keys required to turn it on; absent → total no-op. Spin up the
# local stack with `docker compose -f docker/langfuse/docker-compose.yml up -d`,
# then paste the bootstrapped keys here (they're local-only throwaways). Self-
# hosted ONLY — reviewed source lands in spans with capture on, so it must not
# leave the box. Distinct from ADR-0044 §7's persisted review trace.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Defaults to the docker/langfuse web port; do not point at Langfuse Cloud (v0).
LANGFUSE_HOST=http://localhost:3200
# Capture full prompt/completion bodies on spans. Defaults ON when keys present
# (most diagnostic on a self-hosted box). Set 0/false for any CI/cloud run.
WARDEN_LANGFUSE_CAPTURE_IO=

# Required — Anthropic API key for the LLM formatter / triage layer.
# Even `warden check` validates this at startup so M2+ doesn't surprise.
ANTHROPIC_API_KEY=sk-ant-xxxx

# Optional — Google Generative AI key. When set, enables the multi-provider
# fallback per ADR-0017: Anthropic primary, Google (gemini-2.5-pro/flash)
# as the second provider when Anthropic fails after one retry.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional — log verbosity. silent | error | warn | info (default) | debug
WARDEN_LOG_LEVEL=info

# Optional — confidence floor for `security`-category findings (ADR-0028).
# Comments below this floor are silently dropped before render; Tier-1
# findings bypass unconditionally (critical-finding short-circuit). Default
# 0.8 lives in @warden/core/confidence.ts; set this to lower or raise it.
# Acceptable values: 0.0–1.0.
WARDEN_SECURITY_CONFIDENCE_FLOOR=

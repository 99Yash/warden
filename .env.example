# Required — Anthropic API key for the LLM formatter / triage layer.
# Even `warden check` validates this at startup so M2+ doesn't surprise.
ANTHROPIC_API_KEY=sk-ant-xxxx

# Optional — Google Generative AI key. When set, enables the multi-provider
# fallback per ADR-0017: Anthropic primary, Google (gemini-2.5-pro/flash)
# as the second provider when Anthropic fails after one retry.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional — log verbosity. silent | error | warn | info (default) | debug
WARDEN_LOG_LEVEL=info

# Optional — confidence floor for `security`-category findings (ADR-0028).
# Comments below this floor are silently dropped before render; Tier-1
# findings bypass unconditionally (critical-finding short-circuit). Default
# 0.8 lives in @warden/core/confidence.ts; set this to lower or raise it.
# Acceptable values: 0.0–1.0.
WARDEN_SECURITY_CONFIDENCE_FLOOR=

# Optional — M14 review-harness boss step cap (ADR-0030). The boss runs as
# a single `streamText` tool-use loop; each round is one step it spends
# dispatching workers or emitting the final comment array. Default 5;
# clamped to [1, 10]. Lower for cost-conscious runs; raise for diffs that
# need deeper adjudication.
WARDEN_REVIEW_BOSS_ROUNDS=

# Optional — M14 review-harness total worker cap across the boss loop
# (ADR-0030). Unset = unbounded (boss self-budgets within the round cap).
# When set, the dispatch tool returns an error to the boss + emits a
# degraded entry past the cap. Positive integer; use the round cap above
# to disable workers entirely (this knob can't be 0).
WARDEN_REVIEW_WORKER_BUDGET=

# Optional — M16 review-time index refresh budget in USD (ADR-0032).
# Default is 0.25 at the review harness call site. Set to 0 to disable
# implicit refresh and keep the existing stale-index banner.
WARDEN_REVIEW_REFRESH_MAX_USD=

# Optional — per-tier dispatch concurrency caps (ADR-0033). Strong = Sonnet
# via getWorkerStrongModel(); cheap = Haiku via getWorkerCheapModel().
# Defaults: 4 strong, 8 cheap. Constructed once per runReview() and acquired
# at the dispatch boundary (runOneDispatch) — throttles both Round 0's
# Promise.all fan-out and the boss-loop's in-loop dispatches. Surfaces as
# one aggregated `worker-concurrency` info entry only when the cap engaged.
# Provider-neutral so M17 + BYOLLM inherit. Positive integer; 0 is rejected.
WARDEN_WORKER_CONCURRENCY_STRONG=
WARDEN_WORKER_CONCURRENCY_CHEAP=

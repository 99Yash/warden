{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "description": "Build all packages for production",
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "!dist/cache/**"]
    },
    "check-types": {
      "description": "Type-check with tsc across all packages",
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "description": "Watch packages for changes",
      "cache": false,
      "persistent": true,
      "interruptible": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "description": "Open Drizzle Studio database GUI",
      "cache": false,
      "persistent": true,
      "interruptible": true
    }
  }
}

{
  "name": "@warden/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "warden": "./dist/index.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "warden": "node --import tsx/esm src/index.ts",
    "smoke:m7": "node --import tsx/esm scripts/smoke-m7-init.mts",
    "smoke:m7-detectors": "node --import tsx/esm scripts/smoke-m7-detectors.mts",
    "smoke:m8-spine": "node --import tsx/esm scripts/smoke-m8-spine.mts",
    "smoke:m9-catastrophic": "node --import tsx/esm scripts/smoke-m9-catastrophic.mts",
    "smoke:m9-large-refactor": "node --import tsx/esm scripts/smoke-m9-large-refactor.mts",
    "smoke:m10-verifier": "node --import tsx/esm scripts/smoke-m10-verifier.mts",
    "smoke:m10-consistency": "node --import tsx/esm scripts/smoke-m10-consistency.mts",
    "smoke:m10": "pnpm smoke:m10-verifier && pnpm smoke:m10-consistency",
    "smoke:m11-lookup": "node --import tsx/esm scripts/smoke-m11-lookup.mts",
    "smoke:m11-verifier": "node --import tsx/esm scripts/smoke-m11-verifier.mts",
    "smoke:m11-no-node-modules": "node --import tsx/esm scripts/smoke-m11-no-node-modules.mts",
    "smoke:m11": "pnpm smoke:m11-lookup && pnpm smoke:m11-verifier && pnpm smoke:m11-no-node-modules",
    "smoke:m12-detector": "node --import tsx/esm scripts/smoke-m12-detector.mts",
    "smoke:m12-sub-agent": "node --import tsx/esm scripts/smoke-m12-sub-agent.mts",
    "smoke:m12": "pnpm smoke:m12-detector && pnpm smoke:m12-sub-agent"
  },
  "dependencies": {
    "@warden/core": "workspace:*",
    "@warden/db": "workspace:*",
    "@warden/env": "workspace:*",
    "commander": "catalog:",
    "log-update": "catalog:",
    "ora": "catalog:",
    "picocolors": "catalog:"
  },
  "devDependencies": {
    "@warden/config": "workspace:*",
    "tsdown": "catalog:",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}

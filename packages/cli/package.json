{
  "name": "@warden/cli",
  "version": "0.0.1",
  "bin": {
    "warden": "./dist/index.js"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "warden": "node --import tsx/esm src/index.ts",
    "smoke:m7": "node --import tsx/esm scripts/smoke-m7-init.mts",
    "smoke:m7-detectors": "node --import tsx/esm scripts/smoke-m7-detectors.mts",
    "smoke:m9-catastrophic": "node --import tsx/esm scripts/smoke-m9-catastrophic.mts",
    "smoke:m9-large-refactor": "node --import tsx/esm scripts/smoke-m9-large-refactor.mts",
    "smoke:prune-readfile-efficiency": "node --import tsx/esm scripts/smoke-prune-readfile-efficiency.mts",
    "smoke:m10-verifier": "node --import tsx/esm scripts/smoke-m10-verifier.mts",
    "smoke:m10-consistency": "node --import tsx/esm scripts/smoke-m10-consistency.mts",
    "smoke:m10": "pnpm smoke:m10-verifier && pnpm smoke:m10-consistency",
    "smoke:m11-lookup": "node --import tsx/esm scripts/smoke-m11-lookup.mts",
    "smoke:m11-verifier": "node --import tsx/esm scripts/smoke-m11-verifier.mts",
    "smoke:m11-no-node-modules": "node --import tsx/esm scripts/smoke-m11-no-node-modules.mts",
    "smoke:m11": "pnpm smoke:m11-lookup && pnpm smoke:m11-verifier && pnpm smoke:m11-no-node-modules",
    "smoke:m12-detector": "node --import tsx/esm scripts/smoke-m12-detector.mts",
    "smoke:m12": "pnpm smoke:m12-detector",
    "smoke:m13-eslint-security": "node --import tsx/esm scripts/smoke-m13-eslint-security.mts",
    "smoke:m13-confidence-floor": "node --import tsx/esm scripts/smoke-m13-confidence-floor.mts",
    "smoke:m13": "pnpm smoke:m13-eslint-security && pnpm smoke:m13-confidence-floor",
    "smoke:bugfloor-verify-citations": "node --import tsx/esm scripts/smoke-bugfloor-verify-citations.mts",
    "smoke:bugfloor-db-automigrate": "node --import tsx/esm scripts/smoke-bugfloor-db-automigrate.mts",
    "smoke:bugfloor-leverage-snippet": "node --import tsx/esm scripts/smoke-bugfloor-leverage-snippet.mts",
    "smoke:bugfloor-gemini-skip-with-tools": "node --import tsx/esm scripts/smoke-bugfloor-gemini-skip-with-tools.mts",
    "smoke:bugfloor-whole-repo-fallback": "node --import tsx/esm scripts/smoke-bugfloor-whole-repo-fallback.mts",
    "smoke:bugfloor": "pnpm smoke:bugfloor-verify-citations && pnpm smoke:bugfloor-db-automigrate && pnpm smoke:bugfloor-leverage-snippet && pnpm smoke:bugfloor-gemini-skip-with-tools && pnpm smoke:bugfloor-whole-repo-fallback",
    "smoke:model-catalog": "node --import tsx/esm scripts/smoke-model-catalog.mts",
    "smoke:rd-cli": "node --import tsx/esm scripts/smoke-rd-cli.mts",
    "smoke:m14-verify-drop": "node --import tsx/esm scripts/smoke-m14-verify-drop.mts",
    "smoke:m14-diff-scope": "node --import tsx/esm scripts/smoke-m14-diff-scope.mts",
    "smoke:m14-empty-diff": "node --import tsx/esm scripts/smoke-m14-empty-diff.mts",
    "smoke:m14-correctness-worker": "node --import tsx/esm scripts/smoke-m14-correctness-worker.mts",
    "smoke:m14-scalability-worker": "node --import tsx/esm scripts/smoke-m14-scalability-worker.mts",
    "smoke:m14-consistency-worker": "node --import tsx/esm scripts/smoke-m14-consistency-worker.mts",
    "smoke:m14-security-worker": "node --import tsx/esm scripts/smoke-m14-security-worker.mts",
    "smoke:m14-committability-worker": "node --import tsx/esm scripts/smoke-m14-committability-worker.mts",
    "smoke:m14-leverage-worker": "node --import tsx/esm scripts/smoke-m14-leverage-worker.mts",
    "smoke:m14-boss-loop": "node --import tsx/esm scripts/smoke-m14-boss-loop.mts",
    "smoke:m14": "pnpm smoke:m14-verify-drop && pnpm smoke:m14-diff-scope && pnpm smoke:m14-empty-diff && pnpm smoke:m14-correctness-worker && pnpm smoke:m14-scalability-worker && pnpm smoke:m14-consistency-worker && pnpm smoke:m14-security-worker && pnpm smoke:m14-committability-worker && pnpm smoke:m14-leverage-worker && pnpm smoke:m14-boss-loop",
    "smoke:m15-eval-suite": "node --import tsx/esm scripts/smoke-m15-eval-suite.mts",
    "smoke:m15-programmatic-dispatch": "node --import tsx/esm scripts/smoke-m15-programmatic-dispatch.mts",
    "smoke:m15-examples-first": "node --import tsx/esm scripts/smoke-m15-examples-first.mts",
    "smoke:m15-gemini-adapter": "node --import tsx/esm scripts/smoke-m15-gemini-adapter.mts",
    "smoke:m15": "pnpm smoke:m15-gemini-adapter && pnpm smoke:m15-examples-first && pnpm smoke:m15-eval-suite && pnpm smoke:m15-programmatic-dispatch",
    "smoke:m16-junction": "node --import tsx/esm scripts/smoke-m16-junction.mts",
    "smoke:m16-reconcile": "node --import tsx/esm scripts/smoke-m16-reconcile.mts",
    "smoke:m16-incremental-refresh": "node --import tsx/esm scripts/smoke-m16-incremental-refresh.mts",
    "smoke:m16-backfill": "node --import tsx/esm scripts/smoke-m16-backfill.mts",
    "smoke:m16": "pnpm smoke:m16-junction && pnpm smoke:m16-reconcile && pnpm smoke:m16-incremental-refresh && pnpm smoke:m16-backfill",
    "smoke:fix-worker-concurrency": "node --import tsx/esm scripts/smoke-fix-worker-concurrency.mts",
    "smoke:fix-29-openai-worker-schema": "node --import tsx/esm scripts/smoke-fix-29-openai-worker-schema.mts",
    "smoke:m18-triage-gate": "node --import tsx/esm scripts/smoke-m18-triage-gate.mts",
    "smoke:m18": "pnpm smoke:m18-triage-gate",
    "smoke:adr-0048-observability": "node --import tsx/esm scripts/smoke-adr-0048-observability.mts",
    "eval": "node --import tsx/esm scripts/eval/run.mts"
  },
  "dependencies": {
    "@warden/core": "workspace:*",
    "@warden/db": "workspace:*",
    "@warden/env": "workspace:*",
    "commander": "catalog:",
    "log-update": "catalog:",
    "ora": "catalog:",
    "picocolors": "catalog:"
  },
  "devDependencies": {
    "@warden/ai": "workspace:*",
    "@warden/config": "workspace:*",
    "tsdown": "catalog:",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}

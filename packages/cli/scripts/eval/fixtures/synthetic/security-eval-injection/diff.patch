+import type { Request, Response } from "express";
+
+/**
+ * POST /exec — runs an expression supplied by the caller. Internal use
+ * only; the route is mounted under an /admin prefix.
+ */
+export function execHandler(req: Request, res: Response): void {
+  const code = req.body.code as string;
+  if (!code) {
+    res.status(400).send("missing code");
+    return;
+  }
+  const result = eval(code);
+  res.json({ result });
+}

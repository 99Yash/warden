+export interface ParsedDate {
+  year: number;
+  month: number;
+  day: number;
+}
+
+export function parseDate(raw: string): ParsedDate | null {
+  debugger;
+  const m = raw.match(/^(\d{4})-(\d{2})-(\d{2})$/);
+  if (!m) return null;
+  console.log("[parseDate] matched:", m);
+  const [, y, mo, d] = m;
+  return { year: Number(y), month: Number(mo), day: Number(d) };
+}

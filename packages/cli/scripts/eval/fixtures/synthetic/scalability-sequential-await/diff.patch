+interface UserSummary {
+  id: string;
+  name: string;
+}
+
+/**
+ * Fetch summaries for a batch of user ids. Used by the user-list page,
+ * which can request up to 200 ids per page render.
+ */
+export async function fetchUserSummaries(ids: string[]): Promise<UserSummary[]> {
+  const out: UserSummary[] = [];
+  for (const id of ids) {
+    const resp = await fetch(`https://api.example.com/users/${id}`);
+    const json = (await resp.json()) as UserSummary;
+    out.push(json);
+  }
+  return out;
+}

+export interface NodeShape {
+  id: string;
+  children: NodeShape[];
+}
+
+/**
+ * Return a deep copy of the given node tree. Used by the editor undo stack.
+ */
+export function deepCloneNode(node: NodeShape): NodeShape {
+  const copy = JSON.parse(JSON.stringify(node)) as NodeShape;
+  return copy;
+}

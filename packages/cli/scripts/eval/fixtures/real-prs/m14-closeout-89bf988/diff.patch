+if (existsSync(TMP_DB)) unlinkSync(TMP_DB);
+if (existsSync(TMP_ROOT)) rmSync(TMP_ROOT, { recursive: true, force: true });
+
+if (failed > 0) {
+  process.stdout.write(`\n${failed} assertion(s) failed\n`);
+  process.exit(1);
+}
+process.stdout.write(`\nall assertions passed\n`);

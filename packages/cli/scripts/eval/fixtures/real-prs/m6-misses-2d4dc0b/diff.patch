+`review()` flow updates:
+
+```ts
+// After existing ecosystem detection:
+const gitignoreResult = await ensureGitignore(input.repoRoot);
+const ensureGitignoreDegradation = gitignoreResult.added ? ["gitignore: added .warden/ entry"] : [];
+
